# --- Rutas del servidor ---
# Raíz donde se encuentra hlds.exe
HLDS_ROOT=C:\servers\cs16

# Directorio del juego (normalmente "cstrike" o "valve")
GAME_DIR=cstrike

# --- Instalación de plugins ---
# Archivo de configuración de Metamod (relativo a la carpeta del juego)
METAMOD_PLUGINS_INI=addons/metamod/plugins.ini

# --- Configuración de compilación ---
BUILD_CONFIG=Release

# --- Parámetros por defecto del servidor ---
DEFAULT_MAP=de_dust2
DEFAULT_MAXPLAYERS=16
# Argumentos adicionales para hlds.exe (ej. +sv_lan 1, -port 27015)
EXTRA_ARGS=